            <column-instance column="[volatility]" derivation="Avg" name="[avg:volatility:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[gics_sector]" derivation="None" name="[none:gics_sector:nk]" pivot="key" type="nominal"/>
            <column-instance column="[scatter_size]" derivation="Sum" name="[sum:scatter_size:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[ticker]" derivation="None" name="[none:ticker:nk]" pivot="key" type="nominal"/>
            <column-instance column="[security]" derivation="None" name="[none:security:nk]" pivot="key" type="nominal"/>
          </datasource-dependencies>
