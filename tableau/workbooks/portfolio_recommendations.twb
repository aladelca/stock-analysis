            <column datatype="string" name="[trade_description]" role="dimension" type="nominal" caption="Trade Description">
              <calculation class="tableau" formula="IF [rebalance_required] THEN [action] + &quot; &quot; + [ticker] + &quot; &quot; + [trade_weight_label] END"/>
            </column>
            <column datatype="real" name="[trade_size]" role="measure" type="quantitative" caption="Trade Size">
              <calculation class="tableau" formula="IF [rebalance_required] THEN [trade_abs_weight] END"/>
            </column>
            <column datatype="string" name="[trade_ticker]" role="dimension" type="nominal" caption="Trade Ticker">
              <calculation class="tableau" formula="IF [rebalance_required] THEN [ticker] END"/>
            </column>
            <column-instance column="[action]" derivation="None" name="[none:action:nk]" pivot="key" type="nominal"/>
            <column-instance column="[trade_ticker]" derivation="None" name="[none:trade_ticker:nk]" pivot="key" type="nominal"/>
            <column-instance column="[security]" derivation="None" name="[none:security:nk]" pivot="key" type="nominal"/>
            <column-instance column="[trade_size]" derivation="Sum" name="[sum:trade_size:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[trade_description]" derivation="None" name="[none:trade_description:nk]" pivot="key" type="nominal"/>
            <column-instance column="[estimated_commission_weight_label]" derivation="None" name="[none:estimated_commission_weight_label:nk]" pivot="key" type="nominal"/>
          </datasource-dependencies>
          <aggregation value="true"/>
        </view>
        <style/>
        <panes>
          <pane selection-relaxation-option="selection-relaxation-disallow">
            <view>
              <breakdown value="auto"/>
            </view>
            <mark class="Bar"/>
            <encodings>
              <color column="[federated.portfolio_dashboard_mart].[none:action:nk]"/>
              <text column="[federated.portfolio_dashboard_mart].[none:trade_description:nk]"/>
              <tooltip column="[federated.portfolio_dashboard_mart].[none:estimated_commission_weight_label:nk]"/>
            </encodings>
            <style>
              <style-rule element="mark">
                <format attr="mark-labels-show" value="true"/>
                <format attr="mark-labels-cull" value="true"/>
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.portfolio_dashboard_mart].[none:action:nk] / [federated.portfolio_dashboard_mart].[none:trade_ticker:nk] / [federated.portfolio_dashboard_mart].[none:security:nk]</rows>
        <cols>[federated.portfolio_dashboard_mart].[sum:trade_size:qk]</cols>
      </table>
      <simple-id uuid="{2B01C47C-AB0F-58F6-B540-12987EAB912D}"/>
    </worksheet>
    <worksheet name="Sector Allocation">
      <table>
        <view>
          <datasources>
            <datasource caption="portfolio_dashboard_mart" name="federated.portfolio_dashboard_mart"/>
          </datasources>
          <datasource-dependencies datasource="federated.portfolio_dashboard_mart">
