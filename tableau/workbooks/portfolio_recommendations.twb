            <column datatype="string" name="[gics_sector]" role="dimension" type="nominal" caption="GICS Sector"/>
            <column datatype="real" name="[sector_target_weight]" role="measure" type="quantitative" caption="Sector Target Weight"/>
            <column-instance column="[gics_sector]" derivation="None" name="[none:gics_sector:nk]" pivot="key" type="nominal"/>
            <column-instance column="[display_target_weight]" derivation="Sum" name="[sum:display_target_weight:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[sector_target_weight]" derivation="Max" name="[max:sector_target_weight:qk]" pivot="key" type="quantitative"/>
